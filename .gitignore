# Terraform state
*.tfstate
*.tfstate.backup

# Terraform working directories
.terraform/

# Terraform lock file (belongs in example dirs, not the module root)
.terraform.lock.hcl

# Local variable files — may contain real credentials
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
